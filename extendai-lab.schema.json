{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "preset": {
      "type": "string"
    },
    "setDefaultAgent": {
      "type": "boolean"
    },
    "defaultAgentName": {
      "description": "Preferred default agent name used only when default_agent is not already configured. Defaults to engineer.",
      "type": "string",
      "minLength": 1
    },
    "defaultVisibleAgent": {
      "description": "Deprecated alias for defaultAgentName. Used only when default_agent is not already configured.",
      "type": "string",
      "minLength": 1
    },
    "preferredVisibleAgent": {
      "description": "Visible primary agent to place first in UI ordering without changing default_agent. Use this to make one expert more prominent while keeping engineer as the default agent.",
      "type": "string",
      "minLength": 1
    },
    "scoringEngineVersion": {
      "type": "string",
      "enum": [
        "v1",
        "v2-shadow",
        "v2"
      ]
    },
    "balanceProviderUsage": {
      "type": "boolean"
    },
    "autoUpdate": {
      "description": "Disable automatic installation of plugin updates when false. Defaults to true.",
      "type": "boolean"
    },
    "manualPlan": {
      "type": "object",
      "properties": {
        "orchestrator": {
          "type": "object",
          "properties": {
            "primary": {
              "type": "string",
              "pattern": "^[^/\\s]+\\/[^\\s]+$"
            },
            "fallback1": {
              "type": "string",
              "pattern": "^[^/\\s]+\\/[^\\s]+$"
            },
            "fallback2": {
              "type": "string",
              "pattern": "^[^/\\s]+\\/[^\\s]+$"
            },
            "fallback3": {
              "type": "string",
              "pattern": "^[^/\\s]+\\/[^\\s]+$"
            }
          },
          "required": [
            "primary",
            "fallback1",
            "fallback2",
            "fallback3"
          ]
        },
        "oracle": {
          "type": "object",
          "properties": {
            "primary": {
              "type": "string",
              "pattern": "^[^/\\s]+\\/[^\\s]+$"
            },
            "fallback1": {
              "type": "string",
              "pattern": "^[^/\\s]+\\/[^\\s]+$"
            },
            "fallback2": {
              "type": "string",
              "pattern": "^[^/\\s]+\\/[^\\s]+$"
            },
            "fallback3": {
              "type": "string",
              "pattern": "^[^/\\s]+\\/[^\\s]+$"
            }
          },
          "required": [
            "primary",
            "fallback1",
            "fallback2",
            "fallback3"
          ]
        },
        "designer": {
          "type": "object",
          "properties": {
            "primary": {
              "type": "string",
              "pattern": "^[^/\\s]+\\/[^\\s]+$"
            },
            "fallback1": {
              "type": "string",
              "pattern": "^[^/\\s]+\\/[^\\s]+$"
            },
            "fallback2": {
              "type": "string",
              "pattern": "^[^/\\s]+\\/[^\\s]+$"
            },
            "fallback3": {
              "type": "string",
              "pattern": "^[^/\\s]+\\/[^\\s]+$"
            }
          },
          "required": [
            "primary",
            "fallback1",
            "fallback2",
            "fallback3"
          ]
        },
        "explorer": {
          "type": "object",
          "properties": {
            "primary": {
              "type": "string",
              "pattern": "^[^/\\s]+\\/[^\\s]+$"
            },
            "fallback1": {
              "type": "string",
              "pattern": "^[^/\\s]+\\/[^\\s]+$"
            },
            "fallback2": {
              "type": "string",
              "pattern": "^[^/\\s]+\\/[^\\s]+$"
            },
            "fallback3": {
              "type": "string",
              "pattern": "^[^/\\s]+\\/[^\\s]+$"
            }
          },
          "required": [
            "primary",
            "fallback1",
            "fallback2",
            "fallback3"
          ]
        },
        "librarian": {
          "type": "object",
          "properties": {
            "primary": {
              "type": "string",
              "pattern": "^[^/\\s]+\\/[^\\s]+$"
            },
            "fallback1": {
              "type": "string",
              "pattern": "^[^/\\s]+\\/[^\\s]+$"
            },
            "fallback2": {
              "type": "string",
              "pattern": "^[^/\\s]+\\/[^\\s]+$"
            },
            "fallback3": {
              "type": "string",
              "pattern": "^[^/\\s]+\\/[^\\s]+$"
            }
          },
          "required": [
            "primary",
            "fallback1",
            "fallback2",
            "fallback3"
          ]
        },
        "fixer": {
          "type": "object",
          "properties": {
            "primary": {
              "type": "string",
              "pattern": "^[^/\\s]+\\/[^\\s]+$"
            },
            "fallback1": {
              "type": "string",
              "pattern": "^[^/\\s]+\\/[^\\s]+$"
            },
            "fallback2": {
              "type": "string",
              "pattern": "^[^/\\s]+\\/[^\\s]+$"
            },
            "fallback3": {
              "type": "string",
              "pattern": "^[^/\\s]+\\/[^\\s]+$"
            }
          },
          "required": [
            "primary",
            "fallback1",
            "fallback2",
            "fallback3"
          ]
        }
      },
      "required": [
        "orchestrator",
        "oracle",
        "designer",
        "explorer",
        "librarian",
        "fixer"
      ],
      "additionalProperties": false
    },
    "presets": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "object",
        "propertyNames": {
          "type": "string"
        },
        "additionalProperties": {
          "type": "object",
          "properties": {
            "model": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "minItems": 1,
                  "type": "array",
                  "items": {
                    "anyOf": [
                      {
                        "type": "string"
                      },
                      {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string"
                          },
                          "variant": {
                            "type": "string"
                          }
                        },
                        "required": [
                          "id"
                        ]
                      }
                    ]
                  }
                }
              ]
            },
            "temperature": {
              "type": "number",
              "minimum": 0,
              "maximum": 2
            },
            "variant": {
              "type": "string"
            },
            "skills": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "mcps": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "prompt": {
              "type": "string",
              "minLength": 1
            },
            "orchestratorPrompt": {
              "type": "string",
              "minLength": 1
            },
            "options": {
              "type": "object",
              "propertyNames": {
                "type": "string"
              },
              "additionalProperties": {}
            },
            "displayName": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        }
      }
    },
    "agents": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "model": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "minItems": 1,
                "type": "array",
                "items": {
                  "anyOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string"
                        },
                        "variant": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "id"
                      ]
                    }
                  ]
                }
              }
            ]
          },
          "temperature": {
            "type": "number",
            "minimum": 0,
            "maximum": 2
          },
          "variant": {
            "type": "string"
          },
          "skills": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "mcps": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "prompt": {
            "type": "string",
            "minLength": 1
          },
          "orchestratorPrompt": {
            "type": "string",
            "minLength": 1
          },
          "options": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {}
          },
          "displayName": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "disabled_agents": {
      "description": "Agent names to disable completely. Disabled agents are not instantiated and cannot be delegated to. Orchestrator and council internal agents (councillor) cannot be disabled. By default, 'observer' is disabled. Remove it from this list and configure a vision-capable model to enable.",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "disabled_mcps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "enabled_mcps": {
      "description": "Opt in to built-in MCP servers that are shipped disabled by default. Use this for slow or environment-sensitive local MCPs such as semantic_scholar_fastmcp.",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "multiplexer": {
      "type": "object",
      "properties": {
        "type": {
          "default": "none",
          "type": "string",
          "enum": [
            "auto",
            "tmux",
            "zellij",
            "none"
          ]
        },
        "layout": {
          "default": "main-vertical",
          "type": "string",
          "enum": [
            "main-horizontal",
            "main-vertical",
            "tiled",
            "even-horizontal",
            "even-vertical"
          ]
        },
        "main_pane_size": {
          "default": 60,
          "type": "number",
          "minimum": 20,
          "maximum": 80
        }
      }
    },
    "tmux": {
      "type": "object",
      "properties": {
        "enabled": {
          "default": false,
          "type": "boolean"
        },
        "layout": {
          "default": "main-vertical",
          "type": "string",
          "enum": [
            "main-horizontal",
            "main-vertical",
            "tiled",
            "even-horizontal",
            "even-vertical"
          ]
        },
        "main_pane_size": {
          "default": 60,
          "type": "number",
          "minimum": 20,
          "maximum": 80
        }
      }
    },
    "websearch": {
      "type": "object",
      "properties": {
        "provider": {
          "default": "exa",
          "type": "string",
          "enum": [
            "exa",
            "tavily"
          ]
        }
      }
    },
    "interview": {
      "type": "object",
      "properties": {
        "maxQuestions": {
          "default": 2,
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "outputFolder": {
          "default": "interview",
          "type": "string",
          "minLength": 1
        },
        "autoOpenBrowser": {
          "default": true,
          "description": "Automatically open the interview UI in your default browser during interactive runs. Disabled automatically in tests and CI.",
          "type": "boolean"
        },
        "port": {
          "default": 0,
          "type": "integer",
          "minimum": 0,
          "maximum": 65535
        },
        "dashboard": {
          "default": false,
          "type": "boolean"
        }
      }
    },
    "sessionManager": {
      "type": "object",
      "properties": {
        "maxSessionsPerAgent": {
          "default": 2,
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "readContextMinLines": {
          "default": 10,
          "type": "integer",
          "minimum": 0,
          "maximum": 1000
        },
        "readContextMaxFiles": {
          "default": 8,
          "type": "integer",
          "minimum": 0,
          "maximum": 50
        }
      }
    },
    "subagentPolicy": {
      "type": "object",
      "properties": {
        "mode": {
          "default": "ultra-minimal",
          "description": "Subagent usage mode: ultra-minimal (strict main-agent-first default), minimal (legacy cache-first low-agent mode), full (all configured subagents), custom (only allowedAgents), main-only (disable built-in orchestratable subagents). Registered agent changes require plugin reload/restart.",
          "type": "string",
          "enum": [
            "full",
            "ultra-minimal",
            "minimal",
            "custom",
            "main-only"
          ]
        },
        "allowedAgents": {
          "description": "Allowed orchestratable subagents when mode is custom. Non-allowed specialists should be treated as main-agent checklists.",
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "runtimeTargets": {
      "type": "object",
      "properties": {
        "opencode": {
          "type": "object",
          "properties": {
            "enabled": {
              "default": false,
              "type": "boolean"
            },
            "configPath": {
              "type": "string",
              "minLength": 1
            },
            "priority": {
              "default": 50,
              "type": "integer",
              "minimum": 0,
              "maximum": 100
            },
            "capabilities": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "claude": {
          "type": "object",
          "properties": {
            "enabled": {
              "default": false,
              "type": "boolean"
            },
            "configPath": {
              "type": "string",
              "minLength": 1
            },
            "priority": {
              "default": 50,
              "type": "integer",
              "minimum": 0,
              "maximum": 100
            },
            "capabilities": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "openclaude": {
          "type": "object",
          "properties": {
            "enabled": {
              "default": false,
              "type": "boolean"
            },
            "configPath": {
              "type": "string",
              "minLength": 1
            },
            "priority": {
              "default": 50,
              "type": "integer",
              "minimum": 0,
              "maximum": 100
            },
            "capabilities": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "codex": {
          "type": "object",
          "properties": {
            "enabled": {
              "default": false,
              "type": "boolean"
            },
            "configPath": {
              "type": "string",
              "minLength": 1
            },
            "priority": {
              "default": 50,
              "type": "integer",
              "minimum": 0,
              "maximum": 100
            },
            "capabilities": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "compatProviders": {
      "type": "object",
      "properties": {
        "enabled": {
          "default": false,
          "type": "boolean"
        },
        "autoDetect": {
          "default": true,
          "type": "boolean"
        },
        "fallbackToOpenCodeOnly": {
          "default": true,
          "type": "boolean"
        }
      }
    },
    "todoContinuation": {
      "type": "object",
      "properties": {
        "maxContinuations": {
          "default": 5,
          "description": "Maximum consecutive auto-continuations before stopping to ask user",
          "type": "integer",
          "minimum": 1,
          "maximum": 50
        },
        "cooldownMs": {
          "default": 3000,
          "description": "Delay in ms before auto-continuing (gives user time to abort)",
          "type": "integer",
          "minimum": 0,
          "maximum": 30000
        },
        "autoEnable": {
          "default": false,
          "description": "Automatically enable auto-continue when the orchestrator session has enough todos",
          "type": "boolean"
        },
        "autoEnableThreshold": {
          "default": 4,
          "description": "Number of todos that triggers auto-enable (only used when autoEnable is true)",
          "type": "integer",
          "minimum": 1,
          "maximum": 50
        }
      }
    },
    "checkpoint": {
      "type": "object",
      "properties": {
        "enabled": {
          "default": true,
          "description": "Enable automatic checkpoint cleanup on startup",
          "type": "boolean"
        },
        "maxAgeMs": {
          "default": 2592000000,
          "description": "Maximum age of checkpoints in milliseconds (default: 30 days)",
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "maxCheckpointsPerSession": {
          "default": 50,
          "description": "Maximum number of checkpoints to keep per session",
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "maxTotalSizeMb": {
          "default": 100,
          "description": "Maximum total size of checkpoint storage in MB (0 = unlimited)",
          "type": "number",
          "minimum": 0
        }
      }
    },
    "bioSkills": {
      "type": "object",
      "properties": {
        "enabled": {
          "default": false,
          "description": "Enable bio skills catalog and on-demand loading",
          "type": "boolean"
        },
        "repoPath": {
          "description": "Path to bioSkills repository. Defaults to bundled resources/bioSkills in the plugin package, falling back to legacy Future/clone/bioSkills",
          "type": "string"
        },
        "allowedAgents": {
          "default": [
            "*"
          ],
          "description": "Agents that can see bio skills catalog. Default [\"*\"] = all agents",
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "compression": {
      "type": "object",
      "properties": {
        "enabled": {
          "default": false,
          "description": "Enable context-pressure awareness and automatic checkpoint/compression guidance",
          "type": "boolean"
        },
        "strategy": {
          "default": "auto",
          "description": "Compression strategy: auto (automatic), manual (user-triggered), hybrid (both)",
          "type": "string",
          "enum": [
            "auto",
            "manual",
            "hybrid"
          ]
        },
        "thresholdTokens": {
          "default": 100000,
          "description": "Token threshold to trigger automatic compression",
          "type": "number",
          "minimum": 1000
        },
        "preserveRecent": {
          "default": 10,
          "description": "Number of recent messages to preserve from compression",
          "type": "number",
          "minimum": 1
        },
        "profiles": {
          "description": "Optional per-profile L1/L2/L3 ratios. Ratios are applied to the actual context limit reported by OpenCode for the current provider/model/session.",
          "type": "object",
          "properties": {
            "engineering": {
              "default": {
                "l1": 0.5,
                "l2": 0.65,
                "l3": 0.8
              },
              "description": "Context-pressure thresholds for engineer/default workflows. Uses actual host-reported context limits rather than guessing model sizes.",
              "type": "object",
              "properties": {
                "l1": {
                  "default": 0.5,
                  "description": "L1 context-pressure ratio threshold (0-1)",
                  "type": "number",
                  "exclusiveMinimum": 0,
                  "exclusiveMaximum": 1
                },
                "l2": {
                  "default": 0.65,
                  "description": "L2 context-pressure ratio threshold (0-1)",
                  "type": "number",
                  "exclusiveMinimum": 0,
                  "exclusiveMaximum": 1
                },
                "l3": {
                  "default": 0.8,
                  "description": "L3 context-pressure ratio threshold (0-1)",
                  "type": "number",
                  "exclusiveMinimum": 0,
                  "exclusiveMaximum": 1
                }
              }
            },
            "bio": {
              "default": {
                "l1": 0.55,
                "l2": 0.7,
                "l3": 0.85
              },
              "description": "Context-pressure thresholds for biological-science workflows. Uses actual host-reported context limits rather than guessing model sizes.",
              "type": "object",
              "properties": {
                "l1": {
                  "default": 0.5,
                  "description": "L1 context-pressure ratio threshold (0-1)",
                  "type": "number",
                  "exclusiveMinimum": 0,
                  "exclusiveMaximum": 1
                },
                "l2": {
                  "default": 0.65,
                  "description": "L2 context-pressure ratio threshold (0-1)",
                  "type": "number",
                  "exclusiveMinimum": 0,
                  "exclusiveMaximum": 1
                },
                "l3": {
                  "default": 0.8,
                  "description": "L3 context-pressure ratio threshold (0-1)",
                  "type": "number",
                  "exclusiveMinimum": 0,
                  "exclusiveMaximum": 1
                }
              }
            }
          }
        }
      }
    },
    "modelPreferences": {
      "type": "object",
      "properties": {
        "enabled": {
          "default": true,
          "description": "Enable model preferences. When false (default free mode), no model binding or recommendations.",
          "type": "boolean"
        },
        "profile": {
          "default": "free",
          "description": "Model profile preset: free (no binding), ds-first (DS via Go), openai (GPT only), openai-go (dual), custom (user-defined)",
          "type": "string",
          "enum": [
            "free",
            "ds-first",
            "openai",
            "openai-go",
            "custom"
          ]
        },
        "customModels": {
          "description": "Per-agent custom model config (only active when profile=custom)",
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "model": {
                "type": "string",
                "description": "provider/model-id format"
              },
              "variant": {
                "description": "reasoning effort: low/medium/high/xhigh/max",
                "type": "string"
              },
              "fallback": {
                "description": "fallback model chain",
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "required": [
              "model"
            ]
          }
        },
        "customModel": {
          "description": "Default model for all agents when enabled (provider/model format). Per-agent overrides take precedence.",
          "type": "string"
        },
        "perAgent": {
          "description": "Per-agent model overrides (agent-name → provider/model or [primary, fallback]). Takes precedence over profile/customModel.",
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            ]
          }
        }
      }
    },
    "promptMode": {
      "type": "object",
      "properties": {
        "defaultMode": {
          "default": "light",
          "description": "Default prompt mode: heavy (Omo 542 lines), light (OMOS 200-300 lines), turbo (OLD-2 58 lines)",
          "type": "string",
          "enum": [
            "heavy",
            "light",
            "turbo"
          ]
        },
        "allowModeSwitch": {
          "default": true,
          "description": "Allow runtime mode switching via /ol-light, /ol-heavy, /ol-turbo commands",
          "type": "boolean"
        },
        "applyToAgents": {
          "default": [
            "orchestrator",
            "bio-orchestrator",
            "deep-worker",
            "prometheus",
            "atlas"
          ],
          "description": "Agents that use mode system. Default: all primary agents",
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "fallback": {
      "type": "object",
      "properties": {
        "enabled": {
          "default": true,
          "type": "boolean"
        },
        "timeoutMs": {
          "default": 15000,
          "type": "number",
          "minimum": 0
        },
        "retryDelayMs": {
          "default": 500,
