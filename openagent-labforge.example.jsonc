{
  // ========== 模型配置 ==========
  "model_preferences": {
    // 启用自定义模型配置
    "enabled": true,
    
    // 预设配置文件：openai | deepseek | mixed
    // openai: 全部使用 OpenAI 模型（GPT-5.5/5.4/5.4-mini）
    // deepseek: 全部使用 DeepSeek 模型（deepseek-chat）
    // mixed: 混合使用（规划用 GPT，执行用 DeepSeek）
    "profile": "mixed",
    
    // 或者手动配置每个 agent 的模型（支持 fallback 数组）
    // "perAgent": {
    //   "orchestrator": ["openai/gpt-5.5", "deepseek/deepseek-chat"],
    //   "deep-worker": ["deepseek/deepseek-chat", "openai/gpt-5.4"]
    // }
  },

  // ========== 提示词模式配置 ==========
  "prompt_mode": {
    // 默认模式：heavy | light | turbo
    // heavy: Omo 风格，542 行，Phase 0-3 工作流，失败恢复
    // light: OMOS 风格，200-300 行，详细委托规则，并行执行（默认）
    // turbo: OLD-2 风格，58 行，"KEEP GOING" 哲学，快速执行
    "defaultMode": "light",
    
    // 是否允许运行时切换模式（通过 /ol-light, /ol-heavy, /ol-turbo 命令）
    "allowModeSwitch": true,
    
    // 应用模式的 agent 列表（默认：所有主 agent）
    "applyToAgents": ["orchestrator", "bio-orchestrator", "deep-worker", "prometheus", "atlas"]
  },

  // ========== Bio Skills 配置 ==========
  "bioSkills": {
    // 是否启用 bio skills
    "enabled": true,
    
    // bioSkills 仓库路径（可选，默认插件包内 resources/bioSkills）
    // "repoPath": "~/bioSkills",
    
    // 允许使用 bio skills 的 agent（* 表示所有 agent）
    "allowedAgents": ["*"]
  },

  // ========== MCP 配置 ==========
  // 禁用特定 MCP（默认启用：context7, grep_app, websearch, semantic_scholar_fastmcp）
  "disabled_mcps": [
    // 扩展 MCP（默认禁用，按需启用）
    "arxiv_mcp",
    "browser_puppeteer",
    "chrome_devtools_mcp",
    "deepwiki_mcp",
    "open_websearch_mcp",
    "paper_search_mcp"
  ],

  // ========== Agent 配置 ==========
  // 禁用特定 agent
  "disabled_agents": [
    "observer"  // 默认禁用 observer
  ],

  // ========== Multiplexer 配置 ==========
  "multiplexer": {
    "type": "auto",  // auto | tmux | zellij | none
    "layout": "main-vertical",
    "main_pane_size": 60
  },

  // ========== Council 配置 ==========
  "council": {
    "councillor_execution_mode": "parallel",
    "timeout": 180000,
    "presets": {
      "default": {
        "analyst": { "model": "openai/gpt-5.4-mini" },
        "critic": { "model": "anthropic/claude-opus-4" }
      }
    }
  },

  // ========== Checkpoint 配置 ==========
  "checkpoint": {
    "enabled": true,
    "auto_trigger": false  // 是否自动触发 checkpoint（基于上下文压力）
  },

  // ========== Compression 配置 ==========
  "compression": {
    "enabled": false,  // 全局开关（默认禁用）
    "strategy": "auto",  // auto | manual | hybrid
    "thresholdTokens": 100000
  }
}
